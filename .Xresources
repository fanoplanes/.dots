! Base16 Grayscale Dark
! Scheme: Alexandre Gavioli (https://github.com/Alexx2/)

#define base00 #101010
#define base01 #252525
#define base02 #464646
#define base03 #525252
#define base04 #ababab
#define base05 #b9b9b9
#define base06 #e3e3e3
#define base07 #f7f7f7
#define base08 #7c7c7c
#define base09 #999999
#define base0A #a0a0a0
#define base0B #8e8e8e
#define base0C #868686
#define base0D #686868
#define base0E #747474
#define base0F #5e5e5e

*.foreground:   base05
#ifdef background_opacity
*.background:   [background_opacity]base00
#else
*.background:   base00
#endif
*.cursorColor:  base05

*.color0:       base00
*.color1:       base08
*.color2:       base0B
*.color3:       base0A
*.color4:       base0D
*.color5:       base0E
*.color6:       base0C
*.color7:       base05

*.color8:       base03
*.color9:       base09
*.color10:      base01
*.color11:      base02
*.color12:      base04
*.color13:      base06
*.color14:      base0F
*.color15:      base07

Xcursor.size: 8

Xft.antialias: 1

Xft.rgba:       rgb
Xft.hinting:    true
Xft.hintstyle:  hintfull
Xft.autohint:   0
Xft.lcdfilter:  lcddefault

#define FONTSIZE 13
xterm*faceName: xft:monospace:size=FONTSIZE,xft:Noto Color Emoji:size=FONTSIZE,xft:Noto Sans Symbols2:size=FONTSIZE,xft:unifont:size=FONTSIZE
URxvt*font:     xft:monospace:size=FONTSIZE,xft:Noto Color Emoji:size=FONTSIZE,xft:Noto Sans Symbols2:size=FONTSIZE,xft:unifont:size=FONTSIZE
URxvt*boldFont: xft:monospace:bold:size=FONTSIZE,xft:Noto Color Emoji:size=FONTSIZE,xft:Noto Sans Symbols2:size=FONTSIZE,xft:unifont:size=FONTSIZE
!URxvt*letterSpace: -1
URxvt*visualBell: true
URxvt*scrollBar: false
URxvt*depth: 32
URxvt.urgentOnBell: true
URxvt.saveLines: 200000
URxvt.secondaryScreen: 1
URxvt.secondaryScroll: 0
URxvt.matcher.button: 1

Xcursor.theme: Adwaita
UXTerm.termName: xterm-256color
UXTerm.vt100.backarrowKey: false
UXTerm.ttyModes: erase ^?

